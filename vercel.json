{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "env": {
    "GEMINI_API_KEY": "@GEMINI_API_KEY",
    "APP_URL": "@APP_URL",
    "DATABASE_URL": "@DATABASE_URL"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
